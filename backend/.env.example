# =============================================================================
# Backend & Agent Worker — copy to .env and fill in values.
# Agent worker uses: API_BASE_URL, INTERNAL_SECRET (and others as needed).
# =============================================================================

# --- Database & Redis ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resona
REDIS_URL=redis://localhost:6379/0
INTERNAL_SECRET=change-me-to-64-random-chars

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- LiveKit ---
# WebSocket URL clients connect to (e.g. wss://your-host/livekit)
LIVEKIT_URL=wss://your-host/livekit
# HTTP URL for LiveKit API (SIP/twirp). Often http://127.0.0.1:7880 when server is local
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_SIP_URI=sip:key@host:5060

# --- Supabase (auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers ---
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GROQ_API_KEY=

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- URL configuration (no trailing slashes) ---
# Backend API base URL. Twilio webhooks, callbacks, agent worker use this.
# Local:   http://localhost:8000
# Prod:    https://your-domain.com   OR   https://your-domain.com/api
API_BASE_URL=http://localhost:8000

# Frontend app URL (for CORS and links).
# Local:   http://localhost:3000
# Prod:    https://your-domain.com
FRONTEND_URL=http://localhost:3000

# Hostname for SIP/origination display (no scheme, no port).
# Local:   localhost
# Prod:    your-domain.com
PUBLIC_HOST=localhost

# Extra CORS origins, comma-separated (e.g. https://app.example.com,https://www.example.com)
CORS_ORIGINS=

# --- App ---
DEV_MODE=true
SECRET_KEY=change-me-to-64-random-chars
