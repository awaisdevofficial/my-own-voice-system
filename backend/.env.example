# =============================================================================
# Backend & Agent Worker — copy to .env and fill in values.
# Agent worker uses: API_BASE_URL, INTERNAL_SECRET (and others as needed).
# =============================================================================

# --- Database & Redis ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/resona
REDIS_URL=redis://localhost:6379/0
INTERNAL_SECRET=change-me-to-64-random-chars

# Twilio credentials are stored per-user in the database (Settings → Phone).

# --- LiveKit ---
# WebSocket URL (browser + agent worker). Use your public domain (e.g. wss://your-domain.com/livekit).
LIVEKIT_URL=wss://your-domain.com/livekit
# HTTP API for creating rooms. Same host: http://127.0.0.1:7880. If backend runs in Docker, use host IP (e.g. http://172.31.18.18:7880).
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# SIP trunk origination (e.g. sip:your_key@your-host:5060)
LIVEKIT_SIP_URI=sip:key@host:5060
# IP where Twilio sends inbound SIP (used for Twilio trunk origination URI)
SIP_SERVER_IP=18.141.140.150

# --- Supabase (auth) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers: Deepgram (STT + TTS), Cartesia (TTS), Groq (LLM) ---
# Set CARTESIA_API_KEY when an agent uses TTS provider "Cartesia" (Settings → Agents → Voice).
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
GROQ_API_KEY=
# Optional: OpenAI API key for agent worker LLM fallback when Groq rate limit (429) is hit.
# OPENAI_API_KEY=

# --- Stripe (optional) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- URL configuration (no trailing slashes) ---
# Backend API base URL. Twilio webhooks, callbacks, agent worker use this.
# Local: http://localhost:8000  |  Prod: https://your-domain.com or https://your-domain.com/api
API_BASE_URL=http://localhost:8000

# Frontend app URL (for CORS and links).
# Local: http://localhost:3000  |  Prod: https://your-domain.com
FRONTEND_URL=http://localhost:3000

# Hostname for SIP/origination display (no scheme, no port). Prod: your-domain.com
PUBLIC_HOST=localhost

# Server deploy: set API_BASE_URL to https://your-domain.com/api, PUBLIC_HOST=your-domain.com,
# LIVEKIT_SIP_URI=sip:your_key@SERVER_IP:5060

# Extra CORS origins, comma-separated. Optional if FRONTEND_URL is the only origin.
CORS_ORIGINS=

# --- App ---
DEV_MODE=true
SECRET_KEY=change-me-to-64-random-chars

# Optional: limit prompt/kb length in LiveKit token to keep request URL safe (defaults: 8000, 500, 4000)
# MAX_SYSTEM_PROMPT_LEN=8000
# MAX_FIRST_MESSAGE_LEN=500
# MAX_KNOWLEDGE_BASE_LEN_FOR_TOKEN=4000
