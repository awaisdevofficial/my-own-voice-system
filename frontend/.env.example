# =============================================================================
# Frontend (Next.js) — copy to .env and set values. Restart dev server after changes.
# For production build, set NEXT_PUBLIC_* in your deployment environment.
# =============================================================================

# --- Backend API (no trailing slash) ---
# All /v1/* requests use this base. Should match backend API_BASE_URL (without /api if you use a prefix).
# Local: http://localhost:8000  |  Prod: https://your-domain.com or https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LiveKit (WebSocket URL for voice/calls) ---
# Should match backend LIVEKIT_URL (e.g. wss://your-domain.com/livekit).
NEXT_PUBLIC_LIVEKIT_URL=wss://your-domain.com/livekit

# --- Twilio SIP (Settings → Integrations) ---
# Origination URI for Twilio trunk (e.g. sip:your_key@your-host:5060).
NEXT_PUBLIC_ORIGINATION_URI=sip:your_key@your-host:5060

# --- Supabase (auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
