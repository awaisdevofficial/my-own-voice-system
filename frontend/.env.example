# =============================================================================
# Frontend (Next.js) — copy to .env and set values. Restart dev server after changes.
# For production build, set NEXT_PUBLIC_* in your deployment environment.
# =============================================================================

# --- Backend API (no trailing slash) ---
# All /v1/* requests use this base.
# Local:       http://localhost:8000
# Production:  https://your-domain.com   OR   https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- LiveKit (WebSocket URL for voice/calls) ---
# e.g. wss://your-host/livekit
NEXT_PUBLIC_LIVEKIT_URL=wss://your-host/livekit

# --- Twilio SIP (Settings → Integrations) ---
# Origination URI for Twilio trunk (e.g. sip:key@host:5060)
NEXT_PUBLIC_ORIGINATION_URI=sip:your_key@your-host:5060

# --- Supabase (auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
